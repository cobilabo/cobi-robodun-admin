{
  "name": "cobi-robodun-admin",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Robodun content admin — edit data/assets for cobi-robodun",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "dev:cloud": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "sync-check": "tsx scripts/sync-check.ts",
    "bump-content-version": "tsx scripts/bump-content-version.ts",
    "seed:firebase": "node scripts/seed-to-firebase.mjs",
    "pull:catalogs": "node scripts/pull-catalogs-from-firebase.mjs",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy:all": "npm run build && firebase deploy --only functions,hosting",
    "deploy:rules": "firebase deploy --only firestore:rules,storage"
  },
  "dependencies": {
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lint": "^6.9.7",
    "@uiw/codemirror-theme-vscode": "^4.25.11",
    "@uiw/react-codemirror": "^4.25.11",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fflate": "^0.8.3",
    "firebase": "^12.16.0",
    "lucide-react": "^0.544.0",
    "multer": "^1.4.5-lts.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "sharp": "^0.33.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "firebase-admin": "^14.2.0",
    "firebase-tools": "^15.24.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "vite": "^6.0.0"
  }
}
