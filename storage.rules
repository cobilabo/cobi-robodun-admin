rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /project/assets/{allPaths=**} {
      allow read, write: if signedIn();
    }

    match /library/{allPaths=**} {
      allow read, write: if signedIn();
    }
  }
}
